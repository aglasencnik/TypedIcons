<Project>
    <ItemGroup>
        <AdditionalFiles Include="typedicons.json"
                         Condition="Exists('typedicons.json')"/>

        <AdditionalFiles Include="$(BaseIntermediateOutputPath)TypedIcons\typedicons.cache.json"
                         Condition="Exists('$(BaseIntermediateOutputPath)TypedIcons\typedicons.cache.json')"/>
    </ItemGroup>
</Project>